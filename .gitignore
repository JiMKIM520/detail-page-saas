# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# GCP service account keys
gcp-service-account.json
*-credentials.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OMC state
.omc/

# Sensitive docs
docs/test-accounts.md

# 파이프라인 생성물 / 채점 리포트 / 템플릿 draft (배포 무관)
output/
templates/validation/
agents/templates/*/*-draft.json

# 데모 / 실험 자료 (로컬 참고용, 배포 무관)
demo-v8/
/build_final.js
/fewshot_*.js
/gen_*.js
/prototype_*.html

# 임시 테스트 스크립트 (운영 UI 테스트용 — 배포 후 정리)
scripts/create-test-admin.ts
scripts/test-login.ts
