# 빌드/배포에 불필요한 대용량 파일 (CLI 업로드 abort 방지)
# 런타임 파일시스템 접근은 graceful 처리되므로 테스트에 무관

# 섹션 레퍼런스 이미지 수백 장 (design-researcher가 없으면 빈 배열로 진행)
docs/references/
docs/history/
docs/test/

# 파이프라인 생성물 / 데모 / 채점 리포트
output/
demo-v8/
templates/validation/

# 임시 디렉토리
tmp_nukki/
tmp_nukki_planning/

# assets/fonts 140MB 중 빌드에 정적 import되는 Pretendard 3종만 포함 (나머지 137MB 제외)
assets/fonts/*
!assets/fonts/Pretendard-Regular.otf
!assets/fonts/Pretendard-Bold.otf
!assets/fonts/Pretendard-ExtraBold.otf

# 빌드 캐시 / 의존성
.next/
node_modules/

# 테스트 스크립트 (배포 무관)
scripts/create-test-admin.ts
scripts/create-test-projects.ts
scripts/test-login.ts
scripts/reset-demo.ts
scripts/seed-staff.ts
tests/
playwright.config.ts
